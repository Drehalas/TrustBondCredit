        },
        "withdraw(uint256)": {
          "notice": "Withdraw liquidity (simplified for demo)."
        },
        "withdrawToStaking()": {
          "notice": "Emergency withdraw: move liquidity to single-sided staking. Called when volatility exceeds critical threshold (> 50%). This removes the active liquidity position and moves it to staking for safety."
        }
